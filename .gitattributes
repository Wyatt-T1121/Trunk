# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Assembly
*.asm text eol=lf
*.S   text eol=lf

# C++
*.cpp text eol=lf
*.h   text eol=lf

# Build
Makefile    text eol=lf
*.ld        text eol=lf
*.sh        text eol=lf
*.cfg       text eol=lf

# Binary — never touch line endings
*.o   binary
*.elf binary
*.bin binary
*.iso binary
*.img binary