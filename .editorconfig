root = true

[*]
charset             = utf-8
end_of_line         = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cpp]
indent_style = space
indent_size  = 4

[*.h]
indent_style = space
indent_size  = 4

[*.asm]
indent_style = space
indent_size  = 4

[*.S]
indent_style = space
indent_size  = 4

[Makefile]
indent_style = tab
indent_size  = 4

[*.ld]
indent_style = space
indent_size  = 4

[*.sh]
indent_style = space
indent_size  = 4